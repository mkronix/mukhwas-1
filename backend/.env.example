# -- Server -----------------------------------------------
NODE_ENV=development
HOST=0.0.0.0
PORT=5000
# Public URL shown in startup logs and used as default "base" (set in production, e.g. https://api.example.com)
PUBLIC_BASE_URL=
API_PREFIX=/api/v1
# OpenAPI UI at /api-docs. Unset = on in dev, off in prod. Use true/1/yes/on or false/0/no/off to override.
# ENABLE_SWAGGER=true

# -- Database ---------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=Kasim@123
DB_NAME=mukhwas

# -- JWT --------------------------------------------------
JWT_ACCESS_SECRET=change_this_to_a_long_random_secret_32chars_min
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret_32c
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# -- Security ---------------------------------------------
BCRYPT_ROUNDS=12

# -- Cloudinary -------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=mukhwas_uploads

# -- Email (Resend) ---------------------------------------
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@mukhwas.com

# -- Google OAuth -----------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id

# -- CORS -------------------------------------------------
ALLOWED_ORIGINS=https://www.themukhwascompany.com,https://mukhwas.vercel.app,http://localhost:3000,http://localhost:5173

# -- Upload -----------------------------------------------
MAX_FILE_SIZE_MB=5